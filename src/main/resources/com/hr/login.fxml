<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.hr.ui.LoginController"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="0">

        <!-- Login Card -->
        <VBox fx:id="loginCard" styleClass="login-card" maxWidth="440" spacing="0">

            <!-- Logo area -->
            <VBox alignment="CENTER" spacing="10" styleClass="login-header">
                <Label text="HR" styleClass="login-logo"/>
                <Label text="HR Management System" styleClass="login-app-name"/>
                <Label text="Sign in to continue" styleClass="login-subtitle"/>
            </VBox>

            <!-- Error banner -->
            <Label fx:id="lblError" text="" styleClass="login-error"
                   visible="false" managed="false" wrapText="true"/>

            <!-- Form -->
            <VBox spacing="18" styleClass="login-form">

                <VBox spacing="6">
                    <Label text="Username" styleClass="login-field-label"/>
                    <TextField fx:id="tfUsername" styleClass="login-field"
                               promptText="Enter your username"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Password" styleClass="login-field-label"/>
                    <PasswordField fx:id="pfPassword" styleClass="login-field"
                                   promptText="Enter your password"/>
                </VBox>

                <Button fx:id="btnSignIn" text="Sign In" onAction="#handleLogin"
                        styleClass="login-btn" maxWidth="Infinity"/>

            </VBox>

            <!-- Hint -->
            <VBox alignment="CENTER" styleClass="login-footer" spacing="6">
                <Label text="Demo credentials" styleClass="login-hint-title"/>
                <HBox alignment="CENTER" spacing="20">
                    <Label text="Admin: admin / admin123" styleClass="login-hint"/>
                    <Label text="HR: hr / hr123" styleClass="login-hint"/>
                    <Label text="Emp: emp / emp123" styleClass="login-hint"/>
                </HBox>
            </VBox>

        </VBox>
    </VBox>

</StackPane>
