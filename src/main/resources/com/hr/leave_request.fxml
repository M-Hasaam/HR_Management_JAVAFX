<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hr.ui.LeaveRequestController"
      spacing="0" styleClass="module-pane">

    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="3">
            <Label text="Leave Requests" styleClass="module-title"/>
            <Label text="Review, approve, or reject employee leave applications" styleClass="module-subtitle"/>
        </VBox>
        <HBox HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="cbFilter" prefWidth="140"/>
        <Button text="+ Apply for Leave" onAction="#handleApply" styleClass="btn-primary"/>
    </HBox>

    <!-- Stats bar -->
    <HBox fx:id="statsBar" styleClass="stats-bar" alignment="CENTER_LEFT" spacing="24">
        <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>
        <Label fx:id="lblPending"  text="0 Pending"  styleClass="stats-bar-item-amber"/>
        <Label fx:id="lblApproved" text="0 Approved" styleClass="stats-bar-item-green"/>
        <Label fx:id="lblRejected" text="0 Rejected" styleClass="stats-bar-item-red"/>
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="card-scroll" hbarPolicy="NEVER">
        <FlowPane fx:id="cardPane" hgap="16" vgap="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
        </FlowPane>
    </ScrollPane>

</VBox>
